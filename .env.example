# Server Configuration
PORT=3000
ADMIN_PASSWORD=your_admin_secret_here

# ArcaLive Crawler Configuration
# 인증용 게시글 URL은 서버 실행 후 관리자 탭에서 동적으로 설정합니다.

# 반고닉 허용 여부 (true: 반고닉+고정닉 모두 허용, false: 고정닉만 허용)
ALLOW_HALF_NICK=true

# 프로필 히트맵 최소 활동 일수. 미입력 시 제한 없음.
# MIN_ACTIVE_DAYS=10

# 최근 활동 기한 (마지막 활동이 N일 이내여야 함). 미입력 시 제한 없음.
# MAX_INACTIVE_DAYS=30

# 프로필에서 확인할 대상 채널 목록 (쉼표 구분, badge href 기준). 미입력 시 제한 없음.
# TARGET_CHANNELS=characterai

# 대상 채널의 최소 게시글+댓글 수. 미입력 시 제한 없음.
# MIN_CHANNEL_POSTS=10

# Proxied API Keys
# 현재 지원되는 프록시 목적지 API 키
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Global Rate Limiting & Capacity
MAX_USERS=1000
MAX_ACTIVE_USERS=500
MAX_TOTAL_CONCURRENCY=50
MAX_TOTAL_RPM=1000
MAX_TOTAL_RPD=100000

# Per-User Rate Limiting & Quota
MAX_USER_CONCURRENCY=2
MAX_USER_RPM=20
MAX_USER_RPD=1000

# Quota Refill Mode
# SERVER_QUOTA_REFILL_MODE: 'none' (지급 없음) | 'daily' (매일 자정 리필) | 'monthly' (매월 1일 리필)
SERVER_QUOTA_REFILL_MODE=none

# LOAD_BALANCING_STRATEGY: models.json 내에 동일한 id의 모델이 여러 개 있을 때 교지할당 방식
# 'random' (무작위) | 'round-robin' (1번, 2번, 3번 순차적으로 돌아감)
LOAD_BALANCING_STRATEGY=random

# USER_QUOTA: 개별 유저에게 초기에 지급되는 기본 시작 크레딧 또는 횟수
USER_QUOTA=5000000

# GLOBAL_QUOTA: 서버 전체의 사용량 제한액 (기입하지 않으면 무제한)
# GLOBAL_QUOTA=10000000

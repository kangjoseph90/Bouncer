# 서버 기본 설정
PORT=3000                        # 서버가 실행될 포트 번호
ADMIN_PASSWORD=your_admin_secret_here # 관리자 탭 및 설정 변경 시 사용할 비밀번호

# 로드 밸런싱 방식 (models.json 내에 동일한 alias의 모델이 여러 개 있을 때 선택 방식)
LOAD_BALANCING_STRATEGY=random    # 'random' (무작위) | 'round-robin' (순차)

# 아카라이브 크롤러 설정 (활성 유저 검증 조건)
# 인증용 게시글 URL(AUTH_POST_URL)은 서버 실행 후 관리자 웹 UI에서 동적으로 설정할 수 있습니다.
ALLOW_HALF_NICK=true             # 반고닉 허용 여부 (true: 전체 허용, false: 고정닉만 허용)
MIN_ACTIVE_DAYS=10               # 프로필 히트맵 최소 활동 일수 (미입력 시 제한 없음)
MAX_INACTIVE_DAYS=30             # 마지막 활동 이후 경과 기한 (일 단위, 미입력 시 제한 없음)
TARGET_CHANNELS=characterai      # 확인할 채널 목록 (쉼표 구분, badge href 기준, 미입력 시 제한 없음)
MIN_CHANNEL_POSTS=10             # 대상 채널의 최소 게시글+댓글 합계 (미입력 시 제한 없음)

# 인증 프로세스 보안 설정
AUTH_TOKEN_TTL_MINS=5            # 인증 토큰의 유효 시간 (분 단위, 기본 5분)
AUTH_TOKEN_VERIFY_LIMIT=5        # 토큰 1개당 검증 시도 허용 횟수 (기본 5회)

# 프록시 목적지 API 키
# 실제 API 공급자로부터 발급받은 키를 입력하세요.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 서버 전체 제한 (Global Rate Limiting & Quota)
GLOBAL_MAX_USERS=1000            # 서버 전체 최대 등록 가능 유저 수
GLOBAL_MAX_ACTIVE_USERS=500      # 서버 전체 최대 활성 유저 수
GLOBAL_MAX_CONCURRENCY=50        # 서버 전체 동시 요청 수 제한
GLOBAL_MAX_RPM=1000              # 서버 전체 분당 요청 수 제한
GLOBAL_MAX_RPD=100000            # 서버 전체 일일 요청 수 제한
GLOBAL_QUOTA=10000000            # 서버 전체 총 할당량 (크레딧 기준, 약 100만/$1)
GLOBAL_QUOTA_REFILL_MODE=none    # 리필 모드 ('none', 'daily', 'monthly')

# 개별 유저 제한 (Per-User Rate Limiting & Quota)
USER_MAX_CONCURRENCY=2           # 유저당 동시 요청 수 제한
USER_MAX_RPM=20                  # 유저당 분당 요청 수 제한
USER_MAX_RPD=1000                # 유저당 일일 요청 수 제한
USER_QUOTA=5000000               # 유저당 기본 할당량 (크레딧 기준, 약 100만/$1)
USER_QUOTA_REFILL_MODE=none      # 리필 모드 ('none', 'daily', 'monthly')
